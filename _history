 # . .\n        \"\"\")\n    music.play_tone(600, 100)\n    safe_run(35, 35, 5000)\n\ndef feu_rouge_safe():\n    basic.show_leds(\"\"\"\n        . # # # .\n        # # # # #\n        # # # # #\n        # # # # #\n        . # # # .\n        \"\"\")\n    music.play_tone(200, 100)\n    cuteBot.motors(0, 0)\n    basic.pause(2000)\n\ndef on_forever():\n    feu_vert_safe()\n    feu_orange_safe()\n    feu_rouge_safe()\n\nbasic.forever(on_forever)","pxt.json":"{\n    \"name\": \"Robot feu de signalisation\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"cutebot\": \"github:elecfreaks/pxt-cutebot#v6.2.5\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}}],"shares":[],"lastSaveTime":1777826214913}